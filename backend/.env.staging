# Ambiente de Staging

# Configurações do Servidor
PORT=3001
NODE_ENV=staging

# Configurações do Banco de Dados
DATABASE_URL="postgresql://postgres:postgres@staging-db:5432/capacita_staging"

# Configurações de JWT
JWT_SECRET="staging_secret_key"
JWT_EXPIRATION="1d"

# Configurações de CORS
CORS_ORIGIN="https://staging.capacita-hardware.com" # URL do frontend em staging
