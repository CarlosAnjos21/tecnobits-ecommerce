# Ambiente de Produção

# Configurações do Servidor
PORT=3001
NODE_ENV=production

# Configurações do Banco de Dados
DATABASE_URL="postgresql://postgres:postgres@prod-db:5432/capacita_prod"

# Configurações de JWT
JWT_SECRET="prod_secret_key"
JWT_EXPIRATION="1d"

# Configurações de CORS
CORS_ORIGIN="https://capacita-hardware.com" # URL do frontend em produção
