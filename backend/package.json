{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend do projeto e-commerce",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "start:staging": "NODE_ENV=staging node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "test": "set NODE_OPTIONS=--experimental-vm-modules&& jest --config jest.config.mjs",
    "seed:admin": "node seeds/createAdmin.js",
    "seed:vendor": "node seeds/createVendedor.js",
    "seed:client": "node seeds/createCliente.js",
    "seed:products": "node seeds/createProductsAndCategories.js",
    "seed:test-orders": "node seeds/createTestOrders.js",
    "seed:all": "npm run seed:admin && npm run seed:vendor && npm run seed:client && npm run seed:products && npm run seed:test-orders"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nanoid": "^5.1.5",
    "qrcode.react": "^4.2.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/node": "^20.6.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.22.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
