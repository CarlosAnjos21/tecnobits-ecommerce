# Backend environment example
PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
# Para Supabase, use a URL POOLED (pgBouncer) em DATABASE_URL e a URL DIRETA em DIRECT_URL
# Exemplo (ajuste USER, PASSWORD, HOST e DBNAME conforme seu projeto Supabase):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DBNAME?pgbouncer=true&connection_limit=1&pool_timeout=0&sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
JWT_SECRET=troque_esta_chave
JWT_EXPIRES_IN=7d
# URL do frontend em produção (domínio próprio ou outra hospedagem)
FRONTEND_URL=http://localhost:5173
DIRECT_URL=
