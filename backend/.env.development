# Ambiente de Desenvolvimento

# Configurações do Servidor
PORT=3001
NODE_ENV=development

# Configurações do Banco de Dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/capacita_dev"

# Configurações de JWT
