{
  "info": {
    "name": "Ecommerce API (Full)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "ecommerce-collection-full"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Se houver token no ambiente, injeta Authorization automaticamente",
          "const t = pm.environment.get('token');",
          "if (t) { pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + t }); }"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Product Image",
          "request": {
            "method": "POST",
            "body": { "mode": "formdata", "formdata": [ { "key": "image", "type": "file", "src": "" } ] },
            "url": { "raw": "{{baseUrl}}/api/upload/products", "host": ["{{baseUrl}}"], "path": ["api","upload","products"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (cliente)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cliente Teste\",\n  \"email\": \"{{clienteEmail}}\",\n  \"password\": \"{{clientePassword}}\",\n  \"role\": \"cliente\"\n}"
            }
          }
        },
        {
          "name": "Login Cliente (captura token)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const json = pm.response.json();",
              "if (json && json.token) { pm.environment.set('token', json.token); }",
              "pm.test('Token salvo', () => pm.expect(pm.environment.get('token')).to.be.ok);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{clienteEmail}}\",\n  \"password\": \"{{clientePassword}}\"\n}" }
          }
        },
        {
          "name": "Login Admin (captura token)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const json = pm.response.json(); if (json && json.token) pm.environment.set('token', json.token);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" }
          }
        },
        {
          "name": "Login Vendedor (captura token)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const json = pm.response.json(); if (json && json.token) pm.environment.set('token', json.token);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{vendedorEmail}}\",\n  \"password\": \"{{vendedorPassword}}\"\n}" }
          }
        },
        {
          "name": "Get Profile",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] } }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Cliente Atualizado\"\n}" }
          }
        }
      ]
    },

    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "List All Users",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const arr = pm.response.json(); if (Array.isArray(arr) && arr.length) pm.environment.set('lastUserId', arr[0].id);"
          ] } } ],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] } }
        },
        { "name": "Get User By Id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/users/{{lastUserId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{lastUserId}}"] } } },
        { "name": "Update User", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/users/{{lastUserId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{lastUserId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"status\": \"ativo\"\n}" } } },
        { "name": "Delete User", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/users/{{lastUserId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{lastUserId}}"] } } }
      ]
    },

    {
      "name": "Products",
      "item": [
        { "name": "List All", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] } } },
        { "name": "Get By Id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/products/{{lastProductId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{lastProductId}}"] } } },
        { "name": "List By Seller", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/products/seller/{{sellerId}}", "host": ["{{baseUrl}}"], "path": ["api","products","seller","{{sellerId}}"] } } },
        {
          "name": "Create (admin/vendedor)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json(); if (j && j.id) pm.environment.set('lastProductId', j.id);"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Produto Teste\",\n  \"description\": \"Desc\",\n  \"price\": 199.9,\n  \"stock\": 10,\n  \"images\": [\"/images/x.jpg\"],\n  \"categoryId\": \"{{lastCategoryId}}\"\n}" }
          }
        },
        { "name": "Update (admin/vendedor)", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/products/{{lastProductId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{lastProductId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"price\": 249.9\n}" } } },
        { "name": "Delete (admin/vendedor)", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/products/{{lastProductId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{lastProductId}}"] } } }
      ]
    },

    {
      "name": "Categories",
      "item": [
        { "name": "List All", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api","categories"] } } },
        { "name": "Get By Id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/categories/{{lastCategoryId}}", "host": ["{{baseUrl}}"], "path": ["api","categories","{{lastCategoryId}}"] } } },
        { "name": "List Products in Category", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/categories/{{lastCategoryId}}/products", "host": ["{{baseUrl}}"], "path": ["api","categories","{{lastCategoryId}}","products"] } } },
        { "name": "Create (admin)", "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "const j=pm.response.json(); if(j&&j.id) pm.environment.set('lastCategoryId', j.id);" ] } } ], "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api","categories"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Periféricos\"\n}" } } },
        { "name": "Update (admin)", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/categories/{{lastCategoryId}}", "host": ["{{baseUrl}}"], "path": ["api","categories","{{lastCategoryId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acessórios\"\n}" } } },
        { "name": "Delete (admin)", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/categories/{{lastCategoryId}}", "host": ["{{baseUrl}}"], "path": ["api","categories","{{lastCategoryId}}"] } } }
      ]
    },

    {
      "name": "Cart",
      "item": [
        { "name": "Get Cart", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api","cart"] } } },
        { "name": "Add Item", "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "const j=pm.response.json(); if(j.items && j.items[0]) pm.environment.set('lastCartItemId', j.items[0].id);" ] } } ], "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api","cart"] }, "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{lastProductId}}\",\n  \"quantity\": 1\n}" } } },
        { "name": "Update Item Qty", "request": { "method": "PATCH", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/cart/{{lastCartItemId}}", "host": ["{{baseUrl}}"], "path": ["api","cart","{{lastCartItemId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"quantity\": 2\n}" } } },
        { "name": "Remove Item", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/cart/{{lastCartItemId}}", "host": ["{{baseUrl}}"], "path": ["api","cart","{{lastCartItemId}}"] } } }
      ]
    },

    {
      "name": "Orders",
      "item": [
        { "name": "List My Orders", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api","orders"] } } },
        { "name": "Create Order", "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "const j=pm.response.json(); if(j&&j.id) pm.environment.set('lastOrderId', j.id);" ] } } ], "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api","orders"] }, "body": { "mode": "raw", "raw": "{\n  \"cep\": \"01000-000\",\n  \"cidade\": \"São Paulo\",\n  \"enderecoEntrega\": \"Rua A, 123\",\n  \"complemento\": \"Ap 10\",\n  \"dataEntregaPrevista\": \"2025-09-30\",\n  \"estado\": \"SP\",\n  \"metodoPagamento\": \"pix\"\n}" } } },
        { "name": "Seller: My Product Orders", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/orders/seller-orders", "host": ["{{baseUrl}}"], "path": ["api","orders","seller-orders"] } } },
        { "name": "Admin: List All Orders", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/orders/all", "host": ["{{baseUrl}}"], "path": ["api","orders","all"] } } },
        { "name": "Admin: Update Order Status", "request": { "method": "PATCH", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/orders/{{lastOrderId}}", "host": ["{{baseUrl}}"], "path": ["api","orders","{{lastOrderId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"status\": \"shipped\"\n}" } } }
      ]
    },

    {
      "name": "Admin",
      "item": [
        { "name": "Pending Sellers", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/admin/pending-sellers", "host": ["{{baseUrl}}"], "path": ["api","admin","pending-sellers"] } } },
        { "name": "Get Seller By Id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/admin/sellers/{{sellerId}}", "host": ["{{baseUrl}}"], "path": ["api","admin","sellers","{{sellerId}}"] } } },
        { "name": "Update Seller Status", "request": { "method": "PATCH", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/admin/sellers/{{sellerId}}/status", "host": ["{{baseUrl}}"], "path": ["api","admin","sellers","{{sellerId}}","status"] }, "body": { "mode": "raw", "raw": "{\n  \"status\": \"aprovado\"\n}" } } }
      ]
    }
  ]
}
