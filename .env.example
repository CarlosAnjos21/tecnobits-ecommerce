# Configurações do Postman (opcional - para importação automática)
# Obtenha sua API key em: https://account.getpostman.com/access-keys
POSTMAN_API_KEY=your_postman_api_key_here

# ID do workspace onde importar (opcional)
# Encontre o ID na URL do workspace no Postman
POSTMAN_WORKSPACE_ID=your_workspace_id_here

# Exemplo:
# POSTMAN_API_KEY=PMAK-1234567890abcdef
# POSTMAN_WORKSPACE_ID=12345678-1234-1234-1234-123456789012